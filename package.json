{
  "name": "@cloak.dev/perps",
  "version": "0.1.0",
  "description": "Privacy-first perpetuals integration kit. Cloak shielded-pool funding boundary + adapters for Phoenix Eternal (atomic) and Jupiter Perpetuals (async). One PerpVenue interface, one Aggregator that routes across venues.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".":         "./src/index.ts",
    "./core":    "./src/core/index.ts",
    "./cloak":   "./src/cloak/index.ts",
    "./rise":    "./src/rise/index.ts",
    "./jupiter": "./src/jupiter/index.ts",
    "./node":    "./src/node/index.ts"
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test:unit": "tsx test/jupiter/handle.test.ts && tsx test/jupiter/pdas.test.ts",
    "test:reads": "tsx test/jupiter/integration-reads.test.ts",
    "test:writes": "tsx test/jupiter/integration-writes.test.ts",
    "test:free-collateral": "tsx test/jupiter/free-collateral.test.ts",
    "example:rise": "tsx examples/rise-flow.ts",
    "example:jupiter": "tsx examples/jupiter-flow.ts",
    "example:multi-venue": "tsx examples/multi-venue-flow.ts",
    "test:aggregator": "tsx test/core/aggregator.test.ts",
    "test:aggregator-multi": "tsx test/core/aggregator-multi-venue-reads.test.ts",
    "test:streaming": "tsx test/core/aggregator-streaming.test.ts",
    "test:streaming-reemit": "tsx test/core/aggregator-streaming-reemit.test.ts",
    "test:aggregator-writes": "tsx test/core/aggregator-writes.test.ts",
    "test:wallet-adapter": "tsx test/cloak/wallet-adapter-signer.test.ts",
    "test:cloak-on-surfpool": "tsx test/cloak/cloak-on-surfpool.test.ts",
    "test:browser-bundle": "tsx test/browser-bundle.test.ts"
  },
  "dependencies": {
    "@cloak.ag/sdk": "npm:@cloak.dev/sdk@^0.1.6",
    "@coral-xyz/anchor": "^0.29.0",
    "@ellipsis-labs/rise": "^0.4.8",
    "@solana/kit": "^2.0.0",
    "@solana/spl-token": "^0.4.13",
    "@solana/web3.js": "^1.95.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0"
  }
}
